{
  "name": "dep-visualizer",
  "version": "1.0.0",
  "description": "Framework-agnostic dependency visualizer for JavaScript and TypeScript projects. Generates an interactive HTML report of your project's import/dependency tree.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "depviz": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "dependency",
    "visualizer",
    "import",
    "tree",
    "graph",
    "analyzer",
    "typescript",
    "javascript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/dep-visualizer.git"
  },
  "homepage": "https://github.com/your-username/dep-visualizer#readme",
  "bugs": {
    "url": "https://github.com/your-username/dep-visualizer/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "glob": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "ts-node": "^10.9.0"
  }
}
